# Copy this file to ".env" for local development, and set the same values as
# GitHub Actions repository variables/secrets for production (see SUPABASE_SETUP.md).
#
# All variables are exposed to the browser at build time (Vite inlines anything
# prefixed with VITE_). That is expected and safe for the Supabase publishable
# key and the payment URL - never put a secret key (sb_secret_...) here.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Supabase publishable key (sb_publishable_...) - the new replacement for the
# legacy anon key. Safe to expose to the browser; protected by RLS.
VITE_SUPABASE_PUBLISHABLE_KEY=

# The management's payment service link. Users are redirected here after their
# details are logged. Leave blank to disable redirect during development.
VITE_PAYMENT_URL=
